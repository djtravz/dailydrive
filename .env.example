# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored — never commit your actual credentials.

# Spotify App credentials — from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-client-id-here
SPOTIFY_CLIENT_SECRET=your-client-secret-here

# Demeterics API key for taste profile generation (optional)
# Get one at https://demeterics.ai
# DEMETERICS_API_KEY=your-key-here
